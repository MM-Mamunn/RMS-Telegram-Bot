TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
RMS_BACKEND_URL=http://localhost:3000

# The public RMS Telegram AI endpoint. No JWT or auth header is required.
RMS_AGENT_ENDPOINT=/api/agentcalltg

NODE_ENV=development
PORT=8080
REQUEST_TIMEOUT_MS=30000
MAX_USER_MESSAGE_LENGTH=2000
LOG_LEVEL=info
LOG_MESSAGE_CONTENT=false

# Webhook-only settings. Polling does not require these.
BOT_WEBHOOK_PATH=/api/webhook
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
